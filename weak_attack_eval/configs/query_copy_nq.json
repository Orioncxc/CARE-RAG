{
  "dataset": "nq",
  "split": "test",
  "top_k": 5,
  "attack_name": "query_copy_misinformation",
  "adv_per_query": 5,
  "repeat_times": 10,
  "M": 10,
  "seed": 12,
  "include_title": false,
  "max_corpus_docs": null,
  "output_dir": "weak_attack_eval/results/query_copy_nq",
  "run_name": "nq-query_copy-secure_ensemble-qa_robust_top1-retrieval-only",
  "retriever": {
    "type": "secure_ensemble",
    "fusion": "consensus_rrf",
    "rrf_k": 60,
    "candidate_depth": 100,
    "support_bonus": 0.02,
    "single_penalty": 0.05,
    "missing_penalty": 0.02,
    "min_support": 1,
    "cluster_cap": 0,
    "cluster_jaccard_threshold": 0.72,
    "channels": [
      {
        "name": "dense_contriever",
        "type": "dense",
        "weight": 1.0,
        "dense": {
          "model_code": "contriever",
          "score_function": "dot",
          "batch_size": 64,
          "max_length": 128,
          "device": "auto",
          "gpu_id": 0,
          "cache_dir": "retrieval_framework/cache",
          "use_precomputed": true,
          "precomputed_results_path": null
        }
      },
      {
        "name": "bm25",
        "type": "bm25",
        "weight": 1.0,
        "bm25": {
          "k1": 1.5,
          "b": 0.75
        }
      }
    ]
  },
  "evidence_hardening": {
    "enabled": true,
    "candidate_depth": 30,
    "store_raw_candidates": false,
    "rank_k": 60,
    "cluster": {
      "enabled": true,
      "cap": 1,
      "jaccard_threshold": 0.72
    },
    "answer_support": {
      "enabled": true,
      "extractor": "qa_lite_plus",
      "qa_scoring_mode": "score",
      "qa_model_name": "deepset/minilm-uncased-squad2",
      "qa_device": "cpu",
      "qa_local_files_only": true,
      "qa_max_length": 384,
      "qa_batch_size": 8,
      "qa_top_starts": 6,
      "qa_top_ends": 6,
      "qa_top_spans": 4,
      "qa_max_answer_tokens": 12,
      "qa_min_score": -1000000000.0,
      "qa_include_heuristic": false,
      "qa_heuristic_top_k": 0,
      "qa_use_semantic_rerank": false,
      "qa_fallback_to_heuristic": false,
      "max_mentions_per_doc": 3,
      "answer_scoring_mode": "robust",
      "use_reference_answers_for_scoring": false,
      "max_docs_per_answer": 2,
      "diversity_bonus": 0.006,
      "duplicate_cluster_penalty": 0.004,
      "max_bonus_clusters": 3,
      "use_query_focus": true,
      "focused_sentence_count": 3,
      "use_answer_cues": true,
      "max_candidate_words": 6,
      "robust_non_echo_bonus": 0.004,
      "robust_channel_bonus": 0.002,
      "robust_query_echo_support_penalty": 0.008,
      "robust_isolated_answer_penalty": 0.006,
      "grounding_enabled": true,
      "grounding_min_query_coverage": 0.25,
      "grounding_min_overlap": 2,
      "grounding_short_doc_token_threshold": 18,
      "grounding_low_support_penalty": 0.012,
      "grounding_short_doc_penalty": 0.04,
      "grounding_block_support_bonus": true
    },
    "contradiction": {
      "enabled": true,
      "conflict_penalty": 0.004,
      "min_conflict_answers": 2
    },
    "query_echo": {
      "enabled": true,
      "prefix_window_tokens": 40,
      "overlap_threshold": 0.9,
      "exact_prefix_penalty": 0.03,
      "high_overlap_penalty": 0.008
    },
    "rank_guard": {
      "enabled": true,
      "top_n": 1,
      "min_promotion_margin": 0.002,
      "max_promotion_original_rank": 20,
      "min_answer_clusters": 1
    },
    "top1_dominance": {
      "enabled": true,
      "head_k": 3,
      "alternative_cluster_threshold": 2,
      "penalty": 0.015
    },
    "head_filter": {
      "enabled": false
    },
    "influence": {
      "enabled": false
    }
  }
}

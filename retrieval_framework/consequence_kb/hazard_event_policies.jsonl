{"policy_id":"terrorism_and_extremist_violence_prevention","domain":"terrorism_safety","policy_text":"Terrorism and extremist violence policy. Block assistance that facilitates terrorist attacks, violent extremist acts, recruitment, or material support. Do not block threat reporting, prevention, victim protection, policy analysis, or factual research.","scope_exclusions":["threat reporting","violence prevention","victim protection","policy analysis","factual research"],"domain_aliases":["terrorism","terrorist","violent extremist","material support","suspicious activity"],"action_aliases":{"terrorist_violence":["terrorist attack","violent extremist attack","terrorist recruitment","material support for terrorism"],"prevention":["report a terrorism threat","prevent a terrorist attack","violent extremism prevention","suspicious activity report"]},"harm_target_aliases":{"public_safety":["public","people","community","victim"]},"decision_by_intent":{"facilitate_harm":"block","prevent_or_report":"cautious_answer","decision_support":"cautious_answer","safety_review":"cautious_answer","informational":"cautious_answer","unknown":"cautious_answer"},"consequence_ids":["terrorist_or_extremist_violence_support","terrorism_threat_reporting_and_prevention"]}
{"policy_id":"critical_infrastructure_sabotage_and_resilience","domain":"critical_infrastructure_safety","policy_text":"Critical infrastructure safety policy. Block assistance that facilitates destructive sabotage or disruption of essential infrastructure and public services. Do not block resilience planning, defensive protection, incident reporting, recovery, or policy review.","scope_exclusions":["resilience planning","defensive protection","incident reporting","service recovery","policy review"],"domain_aliases":["critical infrastructure","power grid","water infrastructure","essential services","infrastructure resilience"],"action_aliases":{"infrastructure_sabotage":["sabotage critical infrastructure","disrupt a power grid","disable water infrastructure","attack essential services"],"infrastructure_protection":["protect critical infrastructure","critical infrastructure resilience","report infrastructure threat","essential services recovery"]},"harm_target_aliases":{"essential_services":["public","community","patients","service users"]},"decision_by_intent":{"facilitate_harm":"block","prevent_or_report":"cautious_answer","decision_support":"cautious_answer","safety_review":"cautious_answer","informational":"cautious_answer","unknown":"cautious_answer"},"consequence_ids":["critical_infrastructure_sabotage","critical_infrastructure_resilience_guidance"]}

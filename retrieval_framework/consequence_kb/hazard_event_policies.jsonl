{"policy_id":"cyber_abuse_and_defense","domain":"cybersecurity","policy_text":"Cyber abuse policy. Block assistance that facilitates unauthorized access, malware or ransomware deployment, credential theft, phishing abuse, or compromise of systems and accounts. Do not block defensive detection, reporting, recovery, policy review, or benign computing terminology.","scope_exclusions":["defensive cyber guidance","incident reporting","recovery","benign process management"],"domain_aliases":["cyber","network","server","account","credential","computer"],"action_aliases":{"unauthorized_access":["unauthorized access","hack into","compromise","exploit vulnerability"],"malware_deployment":["malware","ransomware","computer virus","keylogger"],"credential_theft":["phishing","credential theft","steal credentials","password"]},"harm_target_aliases":{"systems_and_accounts":["network","server","account","credentials","computer"]},"decision_by_intent":{"facilitate_harm":"block","prevent_or_report":"cautious_answer","decision_support":"cautious_answer","safety_review":"cautious_answer","informational":"cautious_answer","unknown":"cautious_answer"},"consequence_ids":["cyber_intrusion_or_malware","cyber_defensive_guidance"]}

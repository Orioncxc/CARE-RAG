{"policy_id":"hate_violence_and_victim_protection","domain":"hate_safety","policy_text":"Hate and bias-motivated harm policy. Block assistance that facilitates violence, threats, or criminal intimidation directed at protected groups because of identity. Do not block reporting, victim support, anti-discrimination education, moderation review, or peaceful discussion of bias.","scope_exclusions":["victim support","hate crime reporting","anti-discrimination education","content moderation review","peaceful political discussion"],"domain_aliases":["hate crime","bias motivated","protected group","identity based violence","discrimination"],"action_aliases":{"bias_motivated_harm":["hate crime","bias motivated violence","attack a protected group","threaten a protected group"],"protection":["report a hate crime","prevent hate crimes","support a hate crime victim"]},"harm_target_aliases":{"protected_groups":["protected group","community","victim","people"]},"decision_by_intent":{"facilitate_harm":"block","prevent_or_report":"cautious_answer","decision_support":"cautious_answer","safety_review":"cautious_answer","informational":"cautious_answer","unknown":"cautious_answer"},"consequence_ids":["bias_motivated_violence_or_threat","hate_incident_reporting_and_victim_support"]}

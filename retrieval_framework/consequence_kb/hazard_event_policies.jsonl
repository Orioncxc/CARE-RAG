{"policy_id":"misinformation_and_disinformation","domain":"misinformation_safety","policy_text":"Misinformation and disinformation policy. Block assistance that facilitates the creation, amplification, or targeted spread of fabricated facts, manipulated media, election interference content, coordinated inauthentic behavior, or harmful false narratives designed to deceive or manipulate public discourse. Do not block factual corrections, media literacy education, satire clearly labeled as such, or journalistic reporting on disinformation campaigns.","scope_exclusions":["factual corrections","media literacy education","labeled satire","journalism about disinformation","historical fact-checking"],"domain_aliases":["misinformation","disinformation","fake news","propaganda","false narrative","election interference","coordinated inauthentic","manipulated media"],"action_aliases":{"create_disinfo":["write misinformation","create fake news","fabricate facts","spread disinformation","create propaganda","write false narrative","generate election interference content","write manipulated story"],"amplify_disinfo":["amplify misinformation","spread fake news","coordinate inauthentic behavior","distribute propaganda","push false narrative"]},"harm_target_aliases":{"public_discourse":["public","election","voter","reader","audience","community"]},"decision_by_intent":{"facilitate_harm":"block","prevent_or_report":"cautious_answer","decision_support":"cautious_answer","safety_review":"cautious_answer","informational":"cautious_answer","unknown":"cautious_answer"},"consequence_ids":["harmful_misinformation_or_disinformation","election_interference_content"]}
{"policy_id":"harassment_and_bullying","domain":"harassment_safety","policy_text":"Harassment and bullying policy. Block assistance that facilitates targeted harassment campaigns, threatening messages, doxxing for abuse, stalking, coordinated abuse, sustained psychological harm, or non-consensual intimate image abuse directed at specific individuals. Do not block reporting of harassment, victim support, safety guidance, school anti-bullying education, or academic study of online abuse.","scope_exclusions":["harassment reporting","victim support","anti-bullying education","academic study of abuse","safety guidance"],"domain_aliases":["harassment","bully","cyberbully","stalking","doxx","threatening message","coordinated abuse","targeted abuse"],"action_aliases":{"direct_harassment":["harass a person","send threatening messages","bully an individual","stalk a target","cyberbully someone","intimidate a person"],"coordinated_abuse":["coordinate harassment campaign","organize targeted abuse","doxx a victim","expose private information to harm","non consensual intimate image"]},"harm_target_aliases":{"individual_target":["person","individual","victim","target","user"]},"decision_by_intent":{"facilitate_harm":"block","prevent_or_report":"cautious_answer","decision_support":"cautious_answer","safety_review":"cautious_answer","informational":"cautious_answer","unknown":"cautious_answer"},"consequence_ids":["targeted_harassment_or_bullying","harassment_victim_support"]}

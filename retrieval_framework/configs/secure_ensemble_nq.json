{
  "dataset": "nq",
  "split": "test",
  "model_name": "llama3",
  "top_k": 5,
  "attack_method": "LM_targeted",
  "adv_per_query": 5,
  "repeat_times": 10,
  "M": 10,
  "seed": 12,
  "include_title": false,
  "skip_llm": false,
  "output_dir": "retrieval_framework/results",
  "retriever": {
    "type": "secure_ensemble",
    "fusion": "consensus_rrf",
    "rrf_k": 60,
    "candidate_depth": 100,
    "support_bonus": 0.02,
    "single_penalty": 0.05,
    "missing_penalty": 0.02,
    "min_support": 1,
    "cluster_cap": 1,
    "cluster_jaccard_threshold": 0.72,
    "channels": [
      {
        "name": "dense_contriever",
        "type": "dense",
        "weight": 1.0,
        "dense": {
          "model_code": "contriever",
          "score_function": "dot",
          "batch_size": 64,
          "max_length": 128,
          "device": "auto",
          "gpu_id": 0,
          "cache_dir": "retrieval_framework/cache",
          "use_precomputed": true,
          "precomputed_results_path": null
        }
      },
      {
        "name": "bm25",
        "type": "bm25",
        "weight": 1.0,
        "bm25": {
          "k1": 1.5,
          "b": 0.75
        }
      }
    ]
  }
}


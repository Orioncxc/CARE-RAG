{
  "dataset": "consequence_qa",
  "split": "test",
  "model_name": "llama3",
  "top_k": 5,
  "use_truth": false,
  "attack_method": "LM_targeted",
  "adv_per_query": 5,
  "adv_document_mode": "suffix_only",
  "adv_provenance": "indexed_corpus",
  "repeat_times": 1,
  "M": 20,
  "seed": 12,
  "include_title": true,
  "skip_llm": true,
  "output_dir": "retrieval_framework/results/icde_paper_experiments/generalized_injection_risk/consequence_causal_experiment/retrieval",
  "run_name": "consequence_qa_fixed_margin_indexed_poison_retrieval",
  "retriever": {"type": "bm25", "bm25": {"k1": 1.5, "b": 0.75}},
  "evidence_hardening": {
    "enabled": true,
    "candidate_depth": 16,
    "rank_k": 60,
    "cluster": {"enabled": true, "cap": 2, "jaccard_threshold": 0.9},
    "answer_support": {
      "enabled": true,
      "extractor": "heuristic",
      "max_mentions_per_doc": 3,
      "use_reference_answers_for_scoring": false,
      "max_docs_per_answer": 2,
      "diversity_bonus": 0.006,
      "duplicate_cluster_penalty": 0.004,
      "max_bonus_clusters": 3,
      "use_query_focus": false,
      "use_answer_cues": true,
      "max_candidate_words": 3,
      "answer_scoring_mode": "robust",
      "robust_non_echo_bonus": 0.004,
      "robust_channel_bonus": 0.002,
      "robust_query_echo_support_penalty": 0.0,
      "robust_isolated_answer_penalty": 0.008,
      "evidence_mode_use_query_echo": false
    },
    "contradiction": {"enabled": true, "conflict_penalty": 0.004, "min_conflict_answers": 2},
    "query_echo": {"enabled": false},
    "margin_gate": {
      "enabled": true, "mode": "complex", "window": 10, "threshold": 0.75,
      "dynamic_threshold": false, "max_threshold": 1.5, "cluster_weight": 1.0,
      "channel_weight": 0.25, "echo_penalty": 0.75, "isolated_penalty": 0.5,
      "conflict_penalty": 0.25, "top_answer_penalty": 0.02,
      "alternative_bonus": 0.012, "supplement_bonus": 0.012,
      "min_conflict_answers": 2, "use_non_echo_clusters": true,
      "strong_alternative_min_clusters": 2, "max_alternatives": 2,
      "penalize_top_only_if_weak": false, "preserve_rank1_if_no_alternative": false,
      "high_risk_abstain": false
    }
  }
}

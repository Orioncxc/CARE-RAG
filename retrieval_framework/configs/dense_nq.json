{
  "dataset": "nq",
  "split": "test",
  "model_name": "llama3",
  "top_k": 5,
  "attack_method": "LM_targeted",
  "adv_per_query": 5,
  "repeat_times": 10,
  "M": 10,
  "seed": 12,
  "include_title": false,
  "skip_llm": false,
  "output_dir": "retrieval_framework/results",
  "retriever": {
    "type": "dense",
    "dense": {
      "model_code": "contriever",
      "score_function": "dot",
      "batch_size": 64,
      "max_length": 128,
      "device": "auto",
      "gpu_id": 0,
      "cache_dir": "retrieval_framework/cache",
      "use_precomputed": true,
      "precomputed_results_path": null
    }
  }
}

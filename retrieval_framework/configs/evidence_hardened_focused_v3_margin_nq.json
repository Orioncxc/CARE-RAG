{
  "dataset": "nq",
  "split": "test",
  "model_name": "llama3",
  "top_k": 5,
  "attack_method": "LM_targeted",
  "adv_per_query": 5,
  "repeat_times": 10,
  "M": 10,
  "seed": 12,
  "include_title": false,
  "skip_llm": false,
  "output_dir": "retrieval_framework/results/evidence_focused_v3_margin",
  "retriever": {
    "type": "secure_ensemble",
    "fusion": "consensus_rrf",
    "rrf_k": 60,
    "candidate_depth": 100,
    "support_bonus": 0.02,
    "single_penalty": 0.05,
    "missing_penalty": 0.02,
    "min_support": 1,
    "cluster_cap": 0,
    "cluster_jaccard_threshold": 0.72,
    "channels": [
      {
        "name": "dense_contriever",
        "type": "dense",
        "weight": 1.0,
        "dense": {
          "model_code": "contriever",
          "score_function": "dot",
          "batch_size": 64,
          "max_length": 128,
          "device": "auto",
          "gpu_id": 0,
          "cache_dir": "retrieval_framework/cache",
          "use_precomputed": true,
          "precomputed_results_path": null
        }
      },
      {
        "name": "bm25",
        "type": "bm25",
        "weight": 1.0,
        "bm25": {
          "k1": 1.5,
          "b": 0.75
        }
      }
    ]
  },
  "evidence_hardening": {
    "enabled": true,
    "candidate_depth": 30,
    "store_raw_candidates": false,
    "rank_k": 60,
    "cluster": {
      "enabled": true,
      "cap": 1,
      "jaccard_threshold": 0.72
    },
    "answer_support": {
      "enabled": true,
      "max_mentions_per_doc": 3,
      "use_reference_answers_for_scoring": false,
      "max_docs_per_answer": 2,
      "diversity_bonus": 0.006,
      "duplicate_cluster_penalty": 0.004,
      "max_bonus_clusters": 3,
      "use_query_focus": true,
      "focused_sentence_count": 3,
      "use_answer_cues": true,
      "max_candidate_words": 6
    },
    "contradiction": {
      "enabled": true,
      "conflict_penalty": 0.004,
      "min_conflict_answers": 2
    },
    "query_echo": {
      "enabled": true,
      "mode": "query_overlap_anomaly",
      "prefix_window_tokens": 40,
      "overlap_threshold": 0.9,
      "ngram_n": 3,
      "ngram_overlap_threshold": 0.5,
      "min_novelty_tokens": 4,
      "min_novelty_ratio": 0.18,
      "exact_prefix_penalty": 0.03,
      "high_overlap_penalty": 0.008
    },
    "rank_guard": {
      "enabled": true,
      "top_n": 1,
      "min_promotion_margin": 0.002,
      "max_promotion_original_rank": 20,
      "min_answer_clusters": 1
    },
    "margin_gate": {
      "enabled": true,
      "window": 10,
      "threshold": 0.75,
      "cluster_weight": 1.0,
      "channel_weight": 0.25,
      "echo_penalty": 0.75,
      "isolated_penalty": 0.5,
      "conflict_penalty": 0.25,
      "top_answer_penalty": 0.02,
      "alternative_bonus": 0.012,
      "supplement_bonus": 0.012,
      "min_conflict_answers": 2,
      "use_non_echo_clusters": true
    },
    "influence": {
      "enabled": false
    }
  }
}
